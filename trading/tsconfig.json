{
    "compilerOptions": {
        "skipLibCheck": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "esnext",
        "isolatedModules": true,
        "esModuleInterop": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "outDir": "dist",
        "strict": true,
        "paths": {
            "@trpc/server/*": [
                "./node_modules/@trpc/server/*"
            ]
        },
        "lib": [
            "esnext",
            "dom"
        ],
        "types": [
            "node"
        ]
    },
    "exclude": [
        "node_modules"
    ],
    "include": [
        "src/**/*.ts",
        "prisma/generated/**/*"
    ]
}