datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client"
  output          = "./generated"
  previewFeatures = ["strictUndefinedChecks"]
}

model Arbitrage {
  id Int @id @default(autoincrement())

  matchId           Int      @map("match_id")
  //polymarketOutcomeId Int      @map("outcome_id_polymarket")
  //kalshiOutcomeId     Int      @map("outcome_id_kalshi")
  netProfit         Decimal  @map("net_profit")
  grossProfit       Decimal  @map("gross_profit")
  totalFee          Decimal  @map("total_fee")
  estimatedSlippage Decimal  @map("estimaged_slippage")
  detectionTime     DateTime @map("time_deduction")
  executionTime     DateTime @map("time_execution")
  createdAt         DateTime @default(now()) @map("created_at")
  yesPrice       Decimal @map("yes_price")
  noPrice        Decimal @map("no_price")
  polymarketYes  Boolean @map("polymarket_yes")
    shares            Int      @default(1) @map("shares")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Market {
  id Int @id @default(autoincrement())

  platformId     Int      @map("platform_id")
  apiId          String   @map("api_id")
  slug           String?
  title          String
  eventDate      DateTime @map("event_date")
  resolutionDate DateTime @map("resolution_date")
  status         String
  fee            Decimal
  category       String
  createdAt      DateTime @default(now()) @map("created_at")

  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  outcome  Outcome?

  polymarketMatch Match? @relation("polymarket")
  kalshiMatch     Match? @relation("kalshi")
}

model Match {
  id Int @id @default(autoincrement())

  polymarketMarketId Int      @unique @map("polymarket_id")
  kalshiMarketId     Int      @unique @map("kalshi_id")
  matchScore         Float    @map("match_score")
  createdAt          DateTime @default(now()) @map("created_at")

  arbitrages       Arbitrage[]
  polymarketMarket Market      @relation("polymarket", fields: [polymarketMarketId], references: [id], onDelete: Cascade)
  kalshiMarket     Market      @relation("kalshi", fields: [kalshiMarketId], references: [id], onDelete: Cascade)
}

model Outcome {
  id Int @id @default(autoincrement())

  marketId  Int      @unique @map("market_id")
  outcome   String
  createdAt DateTime @default(now()) @map("created_at")

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
}

model Platform {
  id Int @id @default(autoincrement())

  name      String
  baseFee   Decimal  @map("base_fee")
  createdAt DateTime @default(now()) @map("created_at")
  markets   Market[]
}

// for user settings (volume)
model BotConfig {
  id              Int       @id @default(autoincrement())
  usePresetAlgo   Boolean   @default(true) @map("use_preset_algo")  // true = autmated and false = manual
  manualShares    Int       @default(1)    @map("manual_shares")    // this will be used when usePresetAlgo = false
  maxShares       Int       @default(200)  @map("max_shares")       // our cap for our algo
  resolutionStart DateTime? @map("resolution_start")
  resolutionEnd   DateTime? @map("resolution_end")
}

