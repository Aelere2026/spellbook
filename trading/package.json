{
  "name": "server",
  "version": "0.0.0",
  "description": "SPeLL Trading Bot",
  "main": "index.js",
  "scripts": {
    "build": "esbuild src/app.ts --outfile=dist/bundle.js --bundle --sourcemap --watch --platform=node --format=esm --external:./node_modules/*",
    "run": "node --enable-source-maps dist/bundle.js",
    "dev": "concurrently \"npm run build\" \"npm run run\"",
    "build:detector": "esbuild src/detector.ts --outfile=dist/detector.js --bundle --platform=node --format=esm --external:./node_modules/*",
    "detector": "npm run build:detector && node --enable-source-maps dist/detector.js",
    "build:test": "esbuild test/*.test.ts --outdir=dist-tests --bundle --platform=node --format=esm",
    "test": "npm run build:test && node --test dist-tests/*.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.0",
    "@sendgrid/mail": "^8.1.6",
    "@trpc/server": "^11.10.0",
    "ansi-colors": "^4.1.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-static": "^1.2.6",
    "node-fetch": "^3.3.2",
    "pg": "^8.19.0",
    "superjson": "^2.2.6",
    "twilio": "^5.13.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "prisma": "^7.4.2"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
}
